{
  "lsp": {
    "clangd": {
      "binary": {
        "path": "/usr/bin/clangd",
        "arguments": [
          "--query-driver=/opt/gcc-x86_64-elf/bin/x86_64-none-elf-g++",
        ],
      },
    },
  },
}
