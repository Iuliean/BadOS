[
  {
    "label": "Configure x86_64-elf",
    "command": "cmake -S . -B $ZED_WORKTREE_ROOT/build --preset x86_64-elf --fresh",
    "hide": "never",
    "shell": "system",
    // Whether to show the task line in the output of the spawned task, defaults to `true`.
    "show_summary": true,
    // Whether to show the command line in the output of the spawned task, defaults to `true`.
    "show_command": true,
    // Represents the tags for inline runnable indicators, or spawning multiple tasks at once.
    // "tags": []
  },
  {
    "label": "Build",
    "command": "cmake --build $ZED_WORKTREE_ROOT/build",
    "cwd": "$ZED_WORKTREE_ROOT",
    "hide": "never",
    "shell": "system",
    // Whether to show the task line in the output of the spawned task, defaults to `true`.
    "show_summary": true,
    // Whether to show the command line in the output of the spawned task, defaults to `true`.
    "show_command": true,
    // Represents the tags for inline runnable indicators, or spawning multiple tasks at once.
    // "tags": []
  },
  {
    "label": "Install",
    "command": "cmake --install $ZED_WORKTREE_ROOT/build",
    "cwd": "$ZED_WORKTREE_ROOT",
    "hide": "never",
    "shell": "system",
    // Whether to show the task line in the output of the spawned task, defaults to `true`.
    "show_summary": true,
    // Whether to show the command line in the output of the spawned task, defaults to `true`.
    "show_command": true,
    // Represents the tags for inline runnable indicators, or spawning multiple tasks at once.
    // "tags": []
  },
]
